# ===================================
# EGEMAP AUTOMAÇÕES - CONFIGURAÇÃO
# ===================================
# Copie este arquivo para .env e preencha as variáveis

# --- TELEGRAM BOT ---
# Crie seu bot em @BotFather no Telegram e cole o token aqui
TELEGRAM_BOT_TOKEN=seu_token_aqui

# --- CLAUDE AI (Análise da Planta) ---
# Acesse: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-xxxxx

# --- W-VETRO ---
# URL do sistema W-Vetro (sem barra no final)
WVETRO_URL=https://app.wvetro.com.br
# Seu email de login no W-Vetro
WVETRO_EMAIL=seu@email.com
# Sua senha do W-Vetro
WVETRO_SENHA=sua_senha

# --- CONFIGURAÇÕES OPCIONAIS ---
# true = abre o navegador visível (para depuração)
WVETRO_DEBUG=false
# Nível de log: debug, info, warn, error
LOG_LEVEL=info
# Caminho do Chromium (deixe vazio para usar o padrão do Playwright)
CHROMIUM_PATH=
